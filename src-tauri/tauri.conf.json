{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wren",
  "version": "0.1.0",
  "identifier": "com.cascade.wren",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "codesign --force --options runtime --timestamp --sign \"${APPLE_SIGNING_IDENTITY:--}\" src-tauri/resources/libpdfium.dylib",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wren",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.wren/**",
          "$HOME/Library/Mobile Documents/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/*": "./"
    },
    "macOS": {
      "signingIdentity": "${APPLE_SIGNING_IDENTITY:--}",
      "hardenedRuntime": true,
      "minimumSystemVersion": "14.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["wren"]
      }
    }
  }
}
