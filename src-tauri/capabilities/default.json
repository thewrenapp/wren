{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Wren",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "fs:allow-read",
    "fs:allow-read-text-file",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/Wren/**",
        "$DOCUMENT/**",
        "$DOWNLOAD/**",
        "$TEMP/**"
      ]
    }
  ]
}
